scroll: platform-info-test
description: "Minimal test for platform primitive - info, env, check operations"

steps:
  # 1. Get platform info
  - platform:
      operation: info
    output: platform_info

  # 2. Get a specific environment variable
  - platform:
      operation: env
      var: HOME
    output: home_dir

  # 3. Check for a command
  - platform:
      operation: check
      command: git
    output: git_check
